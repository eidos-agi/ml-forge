# --- Step 3: Evaluate ---

def evaluate(model, X_test, y_test, X_train, y_train):
    """Evaluate model and print report."""
    y_pred = model.predict(X_test)

    print("\n=== Model Evaluation ===")
    print(f"Training examples: {len(X_train)}")
    print(f"Test examples: {len(X_test)}")
    print(f"Features: {len(FEATURE_NAMES)}")

    # Accuracy
    acc = accuracy_score(y_test, y_pred)
    print(f"\nAccuracy: {acc:.3f}")

    # Cross-validation
    cv_scores = cross_val_score(model, X_train, y_train, cv=5)
    print(f"Cross-val accuracy: {cv_scores.mean():.3f} (+/- {cv_scores.std():.3f})")

    # Per-class metrics
    print(f"\n{classification_report(y_test, y_pred)}")

    # Confusion matrix
    cm = confusion_matrix(y_test, y_pred)
    print(f"Confusion matrix:\n{cm}")

    # Feature importance (absolute coefficient values)
    print("\n=== Feature Importance ===")
    coefs = model.coef_[0] if model.coef_.ndim > 1 else model.coef_
    importance = sorted(
        zip(FEATURE_NAMES, coefs),
        key=lambda x: abs(x[1]),
        reverse=True,
    )
    for name, coef in importance[:10]:
        print(f"  {name:40s} {coef:+.4f}")

    return acc


# --- Step 4: Export ---

def export_weights(model, accuracy: float, n_train: int, output: str):
    """Export model as JSON weights — this is what ships with the project."""
    coefs = model.coef_[0] if model.coef_.ndim > 1 else model.coef_
    intercept = model.intercept_[0] if hasattr(model.intercept_, '__len__') else model.intercept_

    weights = {
        "model": "{{MODEL_NAME}}",
        "type": "logistic_regression",
        "feature_names": FEATURE_NAMES,
        "coefficients": [round(c, 6) for c in coefs.tolist()],
        "intercept": round(float(intercept), 6),
        "threshold": 0.5,
        "trained_on": n_train,
        "accuracy": round(accuracy, 4),
        "seed": RANDOM_SEED,
    }

    Path(output).write_text(json.dumps(weights, indent=2))
    print(f"\nWeights exported to {output}")
    print(f"Size: {Path(output).stat().st_size} bytes")


# --- Main ---

def main():
    parser = argparse.ArgumentParser(description="Train {{MODEL_NAME}}")
    parser.add_argument("--output", default=OUTPUT_FILE, help="Output weights file")
    args = parser.parse_args()

    random.seed(RANDOM_SEED)

    print("Loading labeled data...")
    X, y = load_labeled_data()
    print(f"  {len(X)} examples, {len(FEATURE_NAMES)} features")

    if len(X) < 20:
        print("WARNING: Very few examples. Model may not generalize.")

    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=TEST_SIZE, random_state=RANDOM_SEED, stratify=y,
    )

    print("Training...")
    model = train(X_train, y_train)

    accuracy = evaluate(model, X_test, y_test, X_train, y_train)

    export_weights(model, accuracy, len(X_train), args.output)


if __name__ == "__main__":
    main()
