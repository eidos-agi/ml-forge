"""
Runtime inference for {{MODEL_NAME}}.

Zero dependencies beyond stdlib. Ships with the project.
Weights are inline constants — trained offline by train.py.

Generated by ml-forge /ml-ship. Do not edit weights manually — retrain instead.
"""
from __future__ import annotations

import math
from typing import Optional


# === Learned weights ===
# Trained on {{N_TRAIN}} examples | Accuracy: {{ACCURACY}} | Seed: {{SEED}}
# Retrain: python train.py --output model_weights.json

FEATURE_NAMES: list[str] = [
    {{#FEATURE_NAMES}}
    "{{.}}",
    {{/FEATURE_NAMES}}
]

COEFFICIENTS: list[float] = [
    {{#COEFFICIENTS}}
    {{.}},
    {{/COEFFICIENTS}}
]

INTERCEPT: float = {{INTERCEPT}}
THRESHOLD: float = {{THRESHOLD}}


# === Inference ===

def predict(features: dict[str, float]) -> float:
    """Return probability score (0.0 to 1.0).

    Args:
        features: dict mapping feature names to float values.
                  Missing features default to 0.0.
    """
    vec = [features.get(name, 0.0) for name in FEATURE_NAMES]
    logit = sum(w * x for w, x in zip(COEFFICIENTS, vec)) + INTERCEPT
    return _sigmoid(logit)


def predict_label(features: dict[str, float]) -> bool:
    """Return True/False prediction based on threshold."""
    return predict(features) >= THRESHOLD


def predict_with_confidence(features: dict[str, float]) -> tuple[bool, float]:
    """Return (prediction, confidence).

    Confidence is distance from the decision boundary:
    - 1.0 = maximally confident
    - 0.5 = on the boundary (uncertain)
    """
    prob = predict(features)
    label = prob >= THRESHOLD
    confidence = abs(prob - THRESHOLD) / max(THRESHOLD, 1.0 - THRESHOLD)
    return label, min(confidence, 1.0)


def explain(features: dict[str, float], top_n: int = 5) -> list[tuple[str, float, float]]:
    """Return top contributing features as (name, contribution, feature_value).

    Contribution = coefficient * feature_value. Sorted by absolute contribution.
    """
    contributions = []
    for name, coef in zip(FEATURE_NAMES, COEFFICIENTS):
        val = features.get(name, 0.0)
        contributions.append((name, coef * val, val))
    contributions.sort(key=lambda x: abs(x[1]), reverse=True)
    return contributions[:top_n]


# === Helpers ===

def _sigmoid(x: float) -> float:
    """Numerically stable sigmoid."""
    if x >= 0:
        return 1.0 / (1.0 + math.exp(-x))
    else:
        ex = math.exp(x)
        return ex / (1.0 + ex)


def load_weights_from_json(path: str) -> None:
    """Hot-reload weights from a JSON file (for development/testing).

    Mutates module-level constants. Not for production use —
    production should use the inline constants above.
    """
    import json
    global FEATURE_NAMES, COEFFICIENTS, INTERCEPT, THRESHOLD

    with open(path) as f:
        w = json.load(f)

    FEATURE_NAMES = w["feature_names"]
    COEFFICIENTS = w["coefficients"]
    INTERCEPT = w["intercept"]
    THRESHOLD = w.get("threshold", 0.5)
