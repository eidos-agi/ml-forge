# --- Evaluate ---

def evaluate(weights: dict, test_features: list[dict], test_labels: list[int], run_baseline: bool):
    """Run full evaluation and print report."""
    threshold = weights.get("threshold", 0.5)

    # Model predictions
    probs = [predict_from_weights(weights, f) for f in test_features]
    preds = [1 if p >= threshold else 0 for p in probs]

    print("=" * 60)
    print(f"MODEL EVALUATION: {weights.get('model', 'unknown')}")
    print("=" * 60)
    print(f"Test examples: {len(test_labels)}")
    print(f"Trained on: {weights.get('trained_on', '?')} examples")
    print(f"Features: {len(weights['feature_names'])}")
    print(f"Training accuracy: {weights.get('accuracy', '?')}")

    # Metrics
    acc = accuracy_score(test_labels, preds)
    prec, rec, f1, _ = precision_recall_fscore_support(test_labels, preds, average="binary", zero_division=0)

    print(f"\n--- Test Metrics ---")
    print(f"Accuracy:  {acc:.3f}")
    print(f"Precision: {prec:.3f}")
    print(f"Recall:    {rec:.3f}")
    print(f"F1:        {f1:.3f}")

    if len(set(test_labels)) == 2:
        auc = roc_auc_score(test_labels, probs)
        print(f"AUC-ROC:   {auc:.3f}")

    # Confusion matrix
    cm = confusion_matrix(test_labels, preds)
    print(f"\nConfusion matrix:\n{cm}")

    # Per-class report
    print(f"\n{classification_report(test_labels, preds, zero_division=0)}")

    # Feature importance
    print("--- Feature Importance (top 10) ---")
    importance = sorted(
        zip(weights["feature_names"], weights["coefficients"]),
        key=lambda x: abs(x[1]),
        reverse=True,
    )
    for name, coef in importance[:10]:
        print(f"  {name:40s} {coef:+.4f}")

    # Dead features
    dead = [name for name, coef in zip(weights["feature_names"], weights["coefficients"]) if abs(coef) < 0.001]
    if dead:
        print(f"\n--- Dead Features (near-zero weight, candidates for removal) ---")
        for name in dead:
            print(f"  {name}")

    # Error analysis
    print("\n--- Error Analysis ---")
    errors = [(i, test_labels[i], preds[i], probs[i]) for i in range(len(preds)) if preds[i] != test_labels[i]]
    print(f"Errors: {len(errors)}/{len(preds)} ({100*len(errors)/len(preds):.1f}%)")
    if errors:
        print("Worst predictions (highest confidence errors):")
        errors.sort(key=lambda x: abs(x[3] - 0.5), reverse=True)
        for idx, true, pred, prob in errors[:5]:
            print(f"  Example {idx}: true={true}, pred={pred}, prob={prob:.3f}")

    # Baseline comparison
    if run_baseline:
        print("\n--- Baseline Comparison ---")
        baseline_preds = [baseline_predict(f) for f in test_features]
        baseline_acc = accuracy_score(test_labels, baseline_preds)
        print(f"Baseline accuracy: {baseline_acc:.3f}")
        print(f"Model accuracy:    {acc:.3f}")
        delta = acc - baseline_acc
        print(f"Delta:             {delta:+.3f} ({'BETTER' if delta > 0 else 'WORSE' if delta < 0 else 'SAME'})")

        if delta < 0.05:
            print("\nWARNING: Model does not beat baseline by >5%. Consider staying with hardcoded approach.")

    # Recommendation
    print("\n--- Recommendation ---")
    if run_baseline:
        if delta > 0.05:
            print("SHIP IT — model beats baseline by meaningful margin.")
        elif delta > 0:
            print("ITERATE — model is slightly better but margin is thin. Look for better features.")
        else:
            print("DON'T SHIP — model doesn't beat baseline. Stay hardcoded or find better features.")
    else:
        if acc > 0.85:
            print(f"Accuracy {acc:.3f} looks good. Run with --baseline to compare against existing approach.")
        else:
            print(f"Accuracy {acc:.3f} is low. Check feature quality with /ml-extract.")


# --- Main ---

def main():
    parser = argparse.ArgumentParser(description="Evaluate {{MODEL_NAME}}")
    parser.add_argument("--weights", default=WEIGHTS_FILE, help="Weights JSON file")
    parser.add_argument("--baseline", action="store_true", help="Compare against baseline approach")
    args = parser.parse_args()

    weights = load_model(args.weights)
    test_features, test_labels = load_test_data()
    evaluate(weights, test_features, test_labels, args.baseline)


if __name__ == "__main__":
    main()
