# --- Load model ---

def load_model(weights_path: str) -> dict:
    """Load weights from JSON."""
    return json.loads(Path(weights_path).read_text())


def predict_from_weights(weights: dict, features: dict[str, float]) -> float:
    """Reproduce inference from weights dict (mirrors model.py logic)."""
    import math
    vec = [features.get(name, 0.0) for name in weights["feature_names"]]
    logit = sum(w * x for w, x in zip(weights["coefficients"], vec)) + weights["intercept"]
    if logit >= 0:
        return 1.0 / (1.0 + math.exp(-logit))
    else:
        ex = math.exp(logit)
        return ex / (1.0 + ex)


