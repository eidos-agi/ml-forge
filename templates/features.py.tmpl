# --- Set similarity helpers ---

def jaccard(a: set, b: set) -> float:
    """Jaccard similarity between two sets. Returns 0.0 if both empty."""
    if not a and not b:
        return 0.0
    return len(a & b) / len(a | b)


def weighted_jaccard(a: set, b: set, weights: dict[str, float]) -> float:
    """Jaccard weighted by item specificity (rarer items = higher weight)."""
    intersection = a & b
    union = a | b
    if not union:
        return 0.0
    num = sum(weights.get(item, 1.0) for item in intersection)
    den = sum(weights.get(item, 1.0) for item in union)
    return num / den


